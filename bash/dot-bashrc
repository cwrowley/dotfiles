# Remove LaTeX build artifacts in the current directory
# Usage: texclean [-n|--dry-run]
texclean() {
    local dryrun=false
    case "${1-}" in -n|--dry-run) dryrun=true ;; esac
    shopt -s nullglob
    local f base ext
    for f in *.tex; do
        base="${f%.tex}"
        for ext in aux log out fdb_latexmk fls synctex.gz toc bbl blg; do
            [ -f "$base.$ext" ] || continue
            if $dryrun; then
                printf '%s\n' "$base.$ext"
            else
                rm -f -- "$base.$ext"
            fi
        done
    done
    shopt -u nullglob
}

