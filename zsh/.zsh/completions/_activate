#compdef activate

_activate() {
  local -a globals
  : "${VENV_HOME:=$HOME/.pyenv}"
  # Match only directories (/) and strip the path, leaving just the tail/basename (:t)
  globals=( "$VENV_HOME"/*(/N:t) )

  _arguments -C \
    '-g[activate global environment]:global env:->global' \
    '1:environment:->env' && return 0

  case $state in
    (global)
      compadd -a globals
      ;;
    (env)
      # Suggest the common local env dirs first, then directories
      compadd .venv venv
      _files -/    # directories only
      ;;
  esac
}
