#compdef tw

_tw() {
  local -a sessions
  # Collect session names (one per line); suppress errors if no server
  # The (f) parameter expansion flag splits the output on newlines into an array
  sessions=( ${(f)"$(tmux list-sessions -F '#S' 2>/dev/null)"} )
  if (( CURRENT == 2 )); then
    compadd -- $sessions
  else
    compadd
  fi
}
